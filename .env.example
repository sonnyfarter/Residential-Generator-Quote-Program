# Server-side only. Never exposed to the client.

# Used by /api/takeoff to call the Anthropic API (claude-sonnet-4-6).
ANTHROPIC_API_KEY=sk-ant-...

# Used by /api/send-email to send branded reports with a PDF attachment (Resend).
# Get a key at https://resend.com. For testing you can leave EMAIL_FROM unset
# (defaults to onboarding@resend.dev, which only sends to your own verified email).
# For production, verify a domain in Resend and set EMAIL_FROM to an address on it.
RESEND_API_KEY=re_...
EMAIL_FROM="Your Company <quotes@yourdomain.com>"
